# Example environment variables

# --- Blockchain / Hardhat ---
# Private key of the relayer wallet that will submit votes on-chain
PRIVATE_KEY=your_relayer_private_key_here
# JSON-RPC endpoint (local Hardhat node or testnet)
RPC_URL=http://127.0.0.1:8545
# Deployed DAOGovernor contract address (printed by scripts/deploy.js)
GOVERNOR_ADDRESS=0xYourDeployedGovernorAddress

# --- Backend ---
MONGODB_URI=mongodb://localhost:27017/dao_voting
PORT=5000
